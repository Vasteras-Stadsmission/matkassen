{
    "name": "matkassen",
    "version": "0.1.0",
    "private": true,
    "engines": {
        "node": "^24.0.0"
    },
    "scripts": {
        "build": "next build",
        "dev": "docker compose -f docker-compose.dev.yml up db -d && ./scripts/wait-for-db.sh && pnpm run db:migrate && next dev --turbopack",
        "dev:build": "docker compose -f docker-compose.dev.yml build",
        "dev:docker": "next dev --turbopack --hostname 0.0.0.0",
        "db:generate": "pnpm drizzle-kit generate",
        "db:migrate": "pnpm drizzle-kit migrate",
        "format-check": "prettier --check .",
        "format": "prettier --write .",
        "lint": "next lint",
        "preview:production": "docker compose -f docker-compose.local.yml up --build",
        "security:check": "node scripts/validate-server-actions.mjs",
        "security:check-api": "node scripts/validate-api-routes.mjs",
        "seed:test-data": "node scripts/seed-test-data.mjs",
        "test": "vitest run",
        "test:unit": "vitest run --project unit",
        "test:integration": "vitest run --project integration",
        "test:watch": "vitest --project unit",
        "test:integration:watch": "vitest --project integration",
        "test:ui": "vitest --ui",
        "test:e2e": "cross-env CI= playwright test",
        "test:e2e:ui": "cross-env CI= playwright test --ui",
        "test:e2e:headed": "cross-env CI= playwright test --headed",
        "test:e2e:debug": "playwright test --debug",
        "test:e2e:report": "playwright show-report",
        "test:e2e:auth": "node scripts/setup-e2e-auth.mjs",
        "test:e2e:check": "./scripts/check-playwright-setup.sh",
        "start": "next start",
        "typecheck": "tsc --noEmit",
        "validate": "pnpm run lint && pnpm run typecheck && pnpm run format-check && pnpm run security:check && pnpm run security:check-api",
        "prepare": "git config core.hooksPath .githooks || true"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@mantine/charts": "^8.3.10",
        "@mantine/core": "^8.3.10",
        "@mantine/dates": "^8.3.10",
        "@mantine/form": "^8.3.10",
        "@mantine/hooks": "^8.3.10",
        "@mantine/modals": "^8.3.10",
        "@mantine/notifications": "^8.3.10",
        "@octokit/auth-app": "^8.2.0",
        "@tabler/icons-react": "^3.44.0",
        "date-fns": "^4.4.0",
        "date-fns-tz": "^3.2.0",
        "drizzle-kit": "^0.31.10",
        "drizzle-orm": "^0.45.2",
        "fast-deep-equal": "^3.1.3",
        "isomorphic-dompurify": "^3.15.0",
        "mantine-datatable": "^8.3.13",
        "marked": "^18.0.4",
        "mermaid": "^11.15.0",
        "minisearch": "^7.2.0",
        "ms": "^2.1.3",
        "nanoid": "^5.1.11",
        "next": "15.5.21",
        "next-auth": "5.0.0-beta.32",
        "next-intl": "^4.13.0",
        "node-cron": "^4.2.1",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "postgres": "^3.4.9",
        "qrcode": "^1.5.4",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "recharts": "^3.8.1"
    },
    "devDependencies": {
        "@electric-sql/pglite": "^0.5.1",
        "@eslint/eslintrc": "^3.3.5",
        "@playwright/mcp": "^0.0.75",
        "@playwright/test": "^1.60.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/ms": "^2.1.0",
        "@types/node": "^24.13.3",
        "@types/node-cron": "^3.0.11",
        "@types/qrcode": "^1.5.6",
        "@types/react": "^19.2.16",
        "@types/react-dom": "^19.2.3",
        "@typescript-eslint/eslint-plugin": "^8.60.1",
        "@typescript-eslint/parser": "^8.60.1",
        "@vitejs/plugin-react": "^5.1.2",
        "@vitest/ui": "^4.1.8",
        "cross-env": "^10.1.0",
        "eslint": "^9.39.2",
        "eslint-config-next": "15.5.20",
        "happy-dom": "^20.9.0",
        "jsdom": "^29.1.1",
        "postcss": "^8.5.15",
        "postcss-preset-mantine": "^1.18.0",
        "postcss-simple-vars": "^7.0.1",
        "prettier": "3.8.3",
        "typescript": "^5.9.3",
        "vite": "^7.3.5",
        "vitest": "^4.1.8"
    },
    "pnpm": {
        "overrides": {
            "esbuild": ">=0.28.1",
            "@eslint/plugin-kit": ">=0.3.4",
            "glob": ">=10.5.0",
            "js-yaml": ">=4.3.0 <5.0.0",
            "flatted": ">=3.4.2",
            "minimatch": ">=10.2.1",
            "yaml": ">=2.8.3",
            "brace-expansion": ">=5.0.7",
            "picomatch": ">=4.0.4",
            "dompurify": ">=3.4.12 <4.0.0",
            "postcss": ">=8.5.10",
            "uuid": ">=14.0.0",
            "ws": ">=8.21.0",
            "undici": ">=7.28.0 <8.0.0",
            "shell-quote": ">=1.9.0 <2.0.0",
            "@babel/core": "7.29.7"
        }
    },
    "packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc"
}
